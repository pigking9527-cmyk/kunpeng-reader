{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "电子书阅读器",
  "version": "0.1.0",
  "identifier": "com.pigking.ebookreader",
  "build": {
    "frontendDist": "./ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "电子书阅读器 - 书架",
        "width": 980,
        "height": 720,
        "minWidth": 480,
        "minHeight": 360,
        "visible": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
